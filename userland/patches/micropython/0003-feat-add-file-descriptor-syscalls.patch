 // Send string of given length
 mp_uint_t mp_hal_stdout_tx_strn(const char *str, mp_uint_t len) {
-    // Unlike POSIX write, the kernel ABI returns zero on complete success and
-    // a positive error code on failure.
-    return os_write(str, len) == 0 ? len : 0;
+    return os_write(OS_STDOUT_FILENO, str, len) == (intptr_t)len ? len : 0;
 }
