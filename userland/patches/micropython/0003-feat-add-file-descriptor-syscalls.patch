     unsigned char c = 0;
     // The kernel read blocks until the first byte is available.  Retry only on
     // an ABI-level error; a successful one-byte request always returns 1.
-    while (os_read(&c, 1) != 1) {
+    while (os_read(OS_STDIN_FILENO, &c, 1) != 1) {
     }
     return c;
