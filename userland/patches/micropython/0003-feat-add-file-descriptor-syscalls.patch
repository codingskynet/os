diff --git a/ports/os/os_syscall.h b/ports/os/os_syscall.h
index 3f7e778..8695301 100644
--- a/ports/os/os_syscall.h
+++ b/ports/os/os_syscall.h
@@ -8,32 +8,49 @@ enum {
     OS_SYSCALL_EXIT = 0,
     OS_SYSCALL_WRITE = 1,
     OS_SYSCALL_READ = 2,
+    OS_SYSCALL_OPEN = 3,
+    OS_SYSCALL_CLOSE = 4,
 };
 
-static inline intptr_t os_syscall(uintptr_t number, uintptr_t arg1, uintptr_t arg2) {
+enum {
+    OS_STDIN_FILENO = 0,
+    OS_STDOUT_FILENO = 1,
+    OS_STDERR_FILENO = 2,
+};
+
+static inline intptr_t os_syscall(uintptr_t number, uintptr_t arg1, uintptr_t arg2, uintptr_t arg3) {
     register uintptr_t a0 __asm ("a0") = number;
     register uintptr_t a1 __asm ("a1") = arg1;
     register uintptr_t a2 __asm ("a2") = arg2;
+    register uintptr_t a3 __asm ("a3") = arg3;
 
     __asm volatile (
         "ecall"
         : "+r" (a0)
-        : "r" (a1), "r" (a2)
+        : "r" (a1), "r" (a2), "r" (a3)
         : "memory"
         );
     return (intptr_t)a0;
 }
 
-static inline intptr_t os_read(void *buffer, size_t len) {
-    return os_syscall(OS_SYSCALL_READ, (uintptr_t)buffer, len);
+static inline intptr_t os_read(int fd, void *buffer, size_t len) {
+    return os_syscall(OS_SYSCALL_READ, (uintptr_t)fd, (uintptr_t)buffer, len);
+}
+
+static inline intptr_t os_write(int fd, const void *buffer, size_t len) {
+    return os_syscall(OS_SYSCALL_WRITE, (uintptr_t)fd, (uintptr_t)buffer, len);
+}
+
+static inline intptr_t os_open(const char *path, size_t len) {
+    return os_syscall(OS_SYSCALL_OPEN, (uintptr_t)path, len, 0);
 }
 
-static inline uintptr_t os_write(const void *buffer, size_t len) {
-    return (uintptr_t)os_syscall(OS_SYSCALL_WRITE, (uintptr_t)buffer, len);
+static inline intptr_t os_close(int fd) {
+    return os_syscall(OS_SYSCALL_CLOSE, (uintptr_t)fd, 0, 0);
 }
 
 static inline __attribute__((noreturn)) void os_exit(uintptr_t status) {
-    (void)os_syscall(OS_SYSCALL_EXIT, status, 0);
+    (void)os_syscall(OS_SYSCALL_EXIT, status, 0, 0);
     __builtin_unreachable();
 }
 
