diff --git a/ports/os/README.md b/ports/os/README.md
index ce37ac2..fd093e4 100644
--- a/ports/os/README.md
+++ b/ports/os/README.md
@@ -4,12 +4,16 @@ This minimal port builds a freestanding RV64 ELF executable for the kernel in
 this repository. It uses the kernel's user syscall ABI directly:
 
 - `a0 = 0`, `a1 = status`: exit
-- `a0 = 1`, `a1 = buffer`, `a2 = length`: console write
-- `a0 = 2`, `a1 = buffer`, `a2 = length`: blocking console read
+- `a0 = 1`, `a1 = fd`, `a2 = buffer`, `a3 = length`: write
+- `a0 = 2`, `a1 = fd`, `a2 = buffer`, `a3 = length`: read
+- `a0 = 3`, `a1 = path`, `a2 = length`: open
+- `a0 = 4`, `a1 = fd`: close
 
 The kernel enters `_start` with a prepared user stack and zero-filled BSS. The
 port initializes `gp`, runs the standard friendly MicroPython REPL, and exits
-through syscall 0 when the REPL finishes.
+through syscall 0 when the REPL finishes. Standard input, output, and error use
+file descriptors 0, 1, and 2. The file reader uses open/read/close, so scripts
+and modules stored in the kernel's init archive can be loaded by MicroPython.
 
 ## Build
 
diff --git a/ports/os/main.c b/ports/os/main.c
index fd12920..d56675b 100644
--- a/ports/os/main.c
+++ b/ports/os/main.c
@@ -1,12 +1,14 @@
 #ifndef NDEBUG
 #include <stdio.h>
 #endif
+#include <string.h>
 
 #include "py/builtin.h"
 #include "py/cstack.h"
 #include "py/gc.h"
 #include "py/lexer.h"
 #include "py/mperrno.h"
+#include "py/reader.h"
 #include "py/runtime.h"
 #include "shared/runtime/gchelper.h"
 #include "shared/runtime/pyexec.h"
@@ -15,6 +17,32 @@
 
 static char heap[MICROPY_HEAP_SIZE];
 
+typedef struct _os_reader_t {
+    int fd;
+    size_t len;
+    size_t pos;
+    byte buffer[32];
+} os_reader_t;
+
+static mp_uint_t os_reader_readbyte(void *data) {
+    os_reader_t *reader = data;
+    if (reader->pos == reader->len) {
+        intptr_t read = os_read(reader->fd, reader->buffer, sizeof(reader->buffer));
+        if (read <= 0) {
+            return MP_READER_EOF;
+        }
+        reader->len = read;
+        reader->pos = 0;
+    }
+    return reader->buffer[reader->pos++];
+}
+
+static void os_reader_close(void *data) {
+    os_reader_t *reader = data;
+    (void)os_close(reader->fd);
+    m_del_obj(os_reader_t, reader);
+}
+
 int main(void) {
     int stack_dummy;
     mp_cstack_init_with_top(&stack_dummy, 0);
@@ -33,13 +61,32 @@ void gc_collect(void) {
 }
 
 mp_lexer_t *mp_lexer_new_from_file(qstr filename) {
-    (void)filename;
-    mp_raise_OSError(MP_ENOENT);
+    const char *path = qstr_str(filename);
+    intptr_t fd = os_open(path, strlen(path));
+    if (fd < 0) {
+        mp_raise_OSError_with_filename(MP_ENOENT, path);
+    }
+
+    os_reader_t *os_reader = m_new_obj(os_reader_t);
+    os_reader->fd = fd;
+    os_reader->len = 0;
+    os_reader->pos = 0;
+
+    mp_reader_t reader = {
+        .data = os_reader,
+        .readbyte = os_reader_readbyte,
+        .close = os_reader_close,
+    };
+    return mp_lexer_new(filename, reader);
 }
 
 mp_import_stat_t mp_import_stat(const char *path) {
-    (void)path;
-    return MP_IMPORT_STAT_NO_EXIST;
+    intptr_t fd = os_open(path, strlen(path));
+    if (fd < 0) {
+        return MP_IMPORT_STAT_NO_EXIST;
+    }
+    (void)os_close(fd);
+    return MP_IMPORT_STAT_FILE;
 }
 
