diff --git a/ports/os/os.ld b/ports/os/os.ld
new file mode 100644
index 0000000..248d07a
--- /dev/null
+++ b/ports/os/os.ld
@@ -0,0 +1,50 @@
+OUTPUT_ARCH(riscv)
+ENTRY(_start)
+
+PHDRS
+{
+    text PT_LOAD FLAGS(5);
+    rodata PT_LOAD FLAGS(4);
+    data PT_LOAD FLAGS(6);
+}
+
+SECTIONS
+{
+    . = 0x10000;
+
+    .text : ALIGN(0x1000)
+    {
+        KEEP(*(.text._start))
+        *(.text .text.*)
+    } :text
+
+    .rodata : ALIGN(0x1000)
+    {
+        *(.rodata .rodata.*)
+        *(.srodata .srodata.*)
+    } :rodata
+
+    .data : ALIGN(0x1000)
+    {
+        __data_start = .;
+        *(.data .data.*)
+        *(.sdata .sdata.*)
+    } :data
+
+    .bss (NOLOAD) : ALIGN(0x1000)
+    {
+        __bss_start = .;
+        *(.bss .bss.*)
+        *(.sbss .sbss.*)
+        *(COMMON)
+        __bss_end = .;
+    } :data
+
+    __global_pointer$ = MIN(__bss_start + 0x800, MAX(__data_start + 0x800, __bss_end - 0x800));
+
+    /DISCARD/ :
+    {
+        *(.eh_frame .eh_frame.*)
+        *(.note .note.*)
+    }
+}
diff --git a/ports/os/os_syscall.h b/ports/os/os_syscall.h
new file mode 100644
index 0000000..3f7e778
--- /dev/null
+++ b/ports/os/os_syscall.h
@@ -0,0 +1,40 @@
+#ifndef MICROPY_INCLUDED_OS_SYSCALL_H
+#define MICROPY_INCLUDED_OS_SYSCALL_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+enum {
+    OS_SYSCALL_EXIT = 0,
+    OS_SYSCALL_WRITE = 1,
+    OS_SYSCALL_READ = 2,
+};
+
+static inline intptr_t os_syscall(uintptr_t number, uintptr_t arg1, uintptr_t arg2) {
+    register uintptr_t a0 __asm ("a0") = number;
+    register uintptr_t a1 __asm ("a1") = arg1;
+    register uintptr_t a2 __asm ("a2") = arg2;
+
+    __asm volatile (
+        "ecall"
+        : "+r" (a0)
+        : "r" (a1), "r" (a2)
+        : "memory"
+        );
+    return (intptr_t)a0;
+}
+
+static inline intptr_t os_read(void *buffer, size_t len) {
+    return os_syscall(OS_SYSCALL_READ, (uintptr_t)buffer, len);
+}
+
+static inline uintptr_t os_write(const void *buffer, size_t len) {
+    return (uintptr_t)os_syscall(OS_SYSCALL_WRITE, (uintptr_t)buffer, len);
+}
+
+static inline __attribute__((noreturn)) void os_exit(uintptr_t status) {
+    (void)os_syscall(OS_SYSCALL_EXIT, status, 0);
+    __builtin_unreachable();
+}
+
+#endif // MICROPY_INCLUDED_OS_SYSCALL_H
diff --git a/ports/os/startup.S b/ports/os/startup.S
new file mode 100644
index 0000000..4b65364
--- /dev/null
+++ b/ports/os/startup.S
@@ -0,0 +1,18 @@
+    .section .text._start, "ax", @progbits
+    .global _start
+    .type _start, @function
+
+_start:
+    .option push
+    .option norelax
+    la gp, __global_pointer$
+    .option pop
+    call main
+    mv a1, a0
+    li a0, 0
+    ecall
+1:
+    j 1b
+
+    .size _start, . - _start
+    .section .note.GNU-stack, "", @progbits
