diff --git a/ports/os/math_shims.c b/ports/os/math_shims.c
new file mode 100644
index 0000000..5b12192
--- /dev/null
+++ b/ports/os/math_shims.c
@@ -0,0 +1,27 @@
+#include <stdint.h>
+
+typedef union _os_double_bits_t {
+    double value;
+    uint64_t bits;
+} os_double_bits_t;
+
+double fabs(double value) {
+    os_double_bits_t bits = {.value = value};
+    bits.bits &= UINT64_C(0x7fffffffffffffff);
+    return bits.value;
+}
+
+double copysign(double magnitude, double sign) {
+    os_double_bits_t magnitude_bits = {.value = magnitude};
+    os_double_bits_t sign_bits = {.value = sign};
+    magnitude_bits.bits =
+        (magnitude_bits.bits & UINT64_C(0x7fffffffffffffff)) |
+        (sign_bits.bits & UINT64_C(0x8000000000000000));
+    return magnitude_bits.value;
+}
+
+double nan(const char *tag) {
+    (void)tag;
+    os_double_bits_t value = {.bits = UINT64_C(0x7ff8000000000000)};
+    return value.value;
+}
