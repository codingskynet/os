diff --git a/library/std/src/sys/pal/os/mod.rs b/library/std/src/sys/pal/os/mod.rs
new file mode 100644
index 00000000..a7bcd0fb
--- /dev/null
+++ b/library/std/src/sys/pal/os/mod.rs
@@ -0,0 +1,93 @@
+//! Platform abstraction for this repository's freestanding user ABI.
+
+use core::arch::asm;
+
+use crate::io;
+
+pub(crate) const STDIN: usize = 0;
+pub(crate) const STDOUT: usize = 1;
+pub(crate) const STDERR: usize = 2;
+
+const EXIT: usize = 0;
+const WRITE: usize = 1;
+const READ: usize = 2;
+const OPEN: usize = 3;
+const CLOSE: usize = 4;
+const SLEEP: usize = 6;
+
+#[inline]
+unsafe fn syscall(number: usize, arg1: usize, arg2: usize, arg3: usize) -> (usize, usize) {
+    let status: usize;
+    let value: usize;
+    unsafe {
+        asm!(
+            "ecall",
+            inlateout("a0") number => status,
+            inlateout("a1") arg1 => value,
+            in("a2") arg2,
+            in("a3") arg3,
+            options(nostack),
+        );
+    }
+    (status, value)
+}
+
+fn result(status: usize, value: usize) -> io::Result<usize> {
+    if status == 0 { Ok(value) } else { Err(io::Error::from_raw_os_error(status as i32)) }
+}
+
+pub(crate) fn read(fd: usize, buffer: &mut [u8]) -> io::Result<usize> {
+    let (status, value) = unsafe { syscall(READ, fd, buffer.as_mut_ptr().addr(), buffer.len()) };
+    result(status, value)
+}
+
+pub(crate) fn write(fd: usize, buffer: &[u8]) -> io::Result<usize> {
+    let (status, value) = unsafe { syscall(WRITE, fd, buffer.as_ptr().addr(), buffer.len()) };
+    result(status, value)
+}
+
+pub(crate) fn open(path: &[u8]) -> io::Result<usize> {
+    let (status, value) = unsafe { syscall(OPEN, path.as_ptr().addr(), path.len(), 0) };
+    result(status, value)
+}
+
+pub(crate) fn close(fd: usize) -> io::Result<()> {
+    let (status, value) = unsafe { syscall(CLOSE, fd, 0, 0) };
+    result(status, value).map(drop)
+}
+
+pub(crate) fn sleep(milliseconds: usize) {
+    let (status, _) = unsafe { syscall(SLEEP, milliseconds, 0, 0) };
+    if status != 0 {
+        abort_internal();
+    }
+}
+
+pub(crate) fn exit(code: i32) -> ! {
+    unsafe {
+        asm!(
+            "ecall",
+            in("a0") EXIT,
+            in("a1") code as isize as usize,
+            options(noreturn),
+        );
+    }
+}
+
+// SAFETY: called once by the Rust runtime before main.
+pub unsafe fn init(_argc: isize, _argv: *const *const u8, _sigpipe: u8) {}
+
+// SAFETY: called once by the Rust runtime after main.
+pub unsafe fn cleanup() {}
+
+pub fn abort_internal() -> ! {
+    exit(134)
+}
+
+pub fn unsupported<T>() -> io::Result<T> {
+    Err(unsupported_err())
+}
+
+pub fn unsupported_err() -> io::Error {
+    io::Error::UNSUPPORTED_PLATFORM
+}
