+        self.create_new = value;
+    }
+}
+
+impl File {
+    pub fn open(path: &Path, options: &OpenOptions) -> io::Result<File> {
+        if !options.read
+            || options.write
+            || options.append
+            || options.truncate
+            || options.create
+            || options.create_new
+        {
+            return Err(io::const_error!(
+                io::ErrorKind::Unsupported,
+                "the OS init archive is read-only",
+            ));
+        }
+
+        let path = path.as_os_str().as_encoded_bytes();
+        if path.is_empty() {
+            return Err(io::const_error!(io::ErrorKind::NotFound, "empty path"));
+        }
+        pal::open(path).map(|fd| File { fd })
+    }
+
+    pub fn file_attr(&self) -> io::Result<FileAttr> {
+        unsupported()
+    }
+
+    pub fn fsync(&self) -> io::Result<()> {
