+++ b/library/std/src/sys/thread/os.rs
@@ -0,0 +1,18 @@
+use crate::time::Duration;
+
+pub fn yield_now() {
+    crate::sys::pal::sleep(0);
+}
+
+pub fn sleep(duration: Duration) {
+    let mut milliseconds = duration.as_millis();
+    if duration.subsec_nanos() % 1_000_000 != 0 {
+        milliseconds = milliseconds.saturating_add(1);
+    }
+
+    while milliseconds != 0 {
+        let chunk = milliseconds.min(usize::MAX as u128) as usize;
+        crate::sys::pal::sleep(chunk);
+        milliseconds -= chunk as u128;
+    }
+}
