@@ -0,0 +1,20 @@
+    .section .text._start, "ax", @progbits
+    .global _start
+    .type _start, @function
+
+_start:
+    .option push
+    .option norelax
+    la gp, __global_pointer$
+    .option pop
+    li a0, 0
+    li a1, 0
+    call main
+    mv a1, a0
+    li a0, 0
+    ecall
+1:
+    j 1b
+
+    .size _start, . - _start
+    .section .note.GNU-stack, "", @progbits
