diff --git a/library/std/src/sys/alloc/os.rs b/library/std/src/sys/alloc/os.rs
new file mode 100644
index 00000000..14667396
--- /dev/null
+++ b/library/std/src/sys/alloc/os.rs
@@ -0,0 +1,71 @@
+#![allow(static_mut_refs)]
+
+use crate::alloc::Layout;
+use crate::ptr;
+use crate::sync::atomic::{AtomicBool, Ordering};
+
+unsafe extern "C" {
+    static mut __heap_start: u8;
+    static mut __heap_end: u8;
+}
+
+static mut DLMALLOC: dlmalloc::Dlmalloc<Os> = dlmalloc::Dlmalloc::new_with_allocator(Os);
+
+struct Os;
+
+unsafe impl dlmalloc::Allocator for Os {
+    fn alloc(&self, _size: usize) -> (*mut u8, usize, u32) {
+        static INITIALIZED: AtomicBool = AtomicBool::new(false);
+        if !INITIALIZED.swap(true, Ordering::Relaxed) {
+            unsafe {
+                (
+                    (&raw mut __heap_start).cast(),
+                    (&raw const __heap_end).offset_from_unsigned(&raw const __heap_start),
+                    0,
+                )
+            }
+        } else {
+            (ptr::null_mut(), 0, 0)
+        }
+    }
+
+    fn remap(&self, _ptr: *mut u8, _old: usize, _new: usize, _can_move: bool) -> *mut u8 {
+        ptr::null_mut()
+    }
+
+    fn free_part(&self, _ptr: *mut u8, _old: usize, _new: usize) -> bool {
+        false
+    }
+
+    fn free(&self, _ptr: *mut u8, _size: usize) -> bool {
+        false
+    }
+
+    fn can_release_part(&self, _flags: u32) -> bool {
+        false
+    }
+
+    fn allocates_zeros(&self) -> bool {
+        true
+    }
+
+    fn page_size(&self) -> usize {
+        4096
+    }
+}
+
+pub unsafe fn alloc(layout: Layout) -> *mut u8 {
+    unsafe { DLMALLOC.malloc(layout.size(), layout.align()) }
+}
+
+pub unsafe fn alloc_zeroed(layout: Layout) -> *mut u8 {
+    unsafe { DLMALLOC.calloc(layout.size(), layout.align()) }
+}
+
+pub unsafe fn dealloc(pointer: *mut u8, layout: Layout) {
+    unsafe { DLMALLOC.free(pointer, layout.size(), layout.align()) }
+}
+
+pub unsafe fn realloc(pointer: *mut u8, layout: Layout, new_size: usize) -> *mut u8 {
+    unsafe { DLMALLOC.realloc(pointer, layout.size(), layout.align(), new_size) }
+}
